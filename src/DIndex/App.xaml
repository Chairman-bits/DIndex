<Application x:Class="DIndex.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBgBrush" Color="#07111F"/>
        <SolidColorBrush x:Key="CardBrush" Color="#101A2B"/>
        <SolidColorBrush x:Key="CardBrush2" Color="#152238"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#2A3A55"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextSubBrush" Color="#BFD0E8"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#60A5FA"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0C1628"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="#3A557D"/>
            <Setter Property="CaretBrush" Value="#60A5FA"/>
            <Setter Property="SelectionBrush" Value="#2563EB"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Background" Value="#16243A"/>
            <Setter Property="BorderBrush" Value="#35527A"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0B1424"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="RowBackground" Value="#0B1424"/>
            <Setter Property="AlternatingRowBackground" Value="#0F1B2E"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#22324B"/>
            <Setter Property="VerticalGridLinesBrush" Value="#22324B"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111C31"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#22324B"/>
        </Style>
    </Application.Resources>
</Application>
