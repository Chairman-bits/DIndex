<Window x:Class="DIndex.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DIndex"
        Width="1360"
        Height="780"
        MinWidth="1060"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBgBrush}"
        Closing="Window_Closing">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="48" Height="48" Background="#0B1424" CornerRadius="12" BorderBrush="#35527A" BorderThickness="1" Margin="0,0,14,0">
                    <TextBlock Text="⌕" Foreground="{StaticResource AccentBrush}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="DIndex" Foreground="{StaticResource TextMainBrush}" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Name="VersionText" Text="タスクトレイ常駐・リアルタイム索引・自動アップデート対応" Foreground="{StaticResource TextSubBrush}" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Name="AddRootButton" Content="フォルダ追加" Click="AddRootButton_Click"/>
                    <Button Name="OpenSettingsButton" Content="設定" Click="OpenSettingsButton_Click"/>
                    <Button Name="UpdateButton" Content="更新確認" Click="UpdateButton_Click"/>
                    <Button Name="RefreshButton" Content="再索引" Click="RefreshButton_Click"/>
                    <Button Content="隠す" Click="HideButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource CardBrush2}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Name="SearchBox" TextChanged="SearchBox_TextChanged" KeyDown="SearchBox_KeyDown" ToolTip="スペース区切りでAND検索。Enterで開く。Ctrl+Enterでフォルダを開く。"/>
                <CheckBox Grid.Column="1" Name="PathSearchCheckBox" Content="パスも検索" Margin="12,0,0,0" Checked="SearchOption_Changed" Unchecked="SearchOption_Changed"/>
                <CheckBox Grid.Column="2" Name="IncludeDirectoriesCheckBox" Content="フォルダも索引" Margin="12,0,0,0" Checked="IncludeDirectories_Changed" Unchecked="IncludeDirectories_Changed"/>
                <TextBlock Grid.Column="3" Name="ResultCountText" Text="0 件" Foreground="{StaticResource TextSubBrush}" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="検索対象フォルダ" Foreground="{StaticResource TextMainBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <ListBox Grid.Row="1" Name="RootList" Background="#0B1424" Foreground="{StaticResource TextMainBrush}" BorderBrush="#22324B"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="追加" Click="AddRootButton_Click" MinWidth="72"/>
                        <Button Content="削除" Click="RemoveRootButton_Click" MinWidth="72"/>
                    </StackPanel>
                </Grid>
            </Border>

            <DataGrid Grid.Column="2" Name="ResultsGrid" AutoGenerateColumns="False" IsReadOnly="True" AlternationCount="2" SelectionMode="Single" MouseDoubleClick="ResultsGrid_MouseDoubleClick">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="開く" Click="OpenSelectedMenu_Click"/>
                        <MenuItem Header="フォルダを開く" Click="OpenParentSelectedMenu_Click"/>
                        <MenuItem Header="パスをコピー" Click="CopyPathSelectedMenu_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="" Binding="{Binding Icon}" Width="44"/>
                    <DataGridTextColumn Header="名前" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="フォルダ" Binding="{Binding Folder}" Width="3*"/>
                    <DataGridTextColumn Header="種類" Binding="{Binding Type}" Width="95"/>
                    <DataGridTextColumn Header="サイズ" Binding="{Binding Size}" Width="110"/>
                    <DataGridTextColumn Header="更新日時" Binding="{Binding Updated}" Width="165"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="3" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="14" Padding="10" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Name="StatusText" Text="初回起動はタスクトレイのみです。ダブルクリックで表示できます。" Foreground="{StaticResource TextSubBrush}" VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" Name="IndexProgressBar" Width="190" Height="12" IsIndeterminate="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>
